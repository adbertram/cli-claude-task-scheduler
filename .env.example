# ClaudeTaskScheduler API Credentials
# Get these from: local://scheduler

# API Key (if using API key auth)
CLAUDE_TASK_SCHEDULER_API_KEY=

# OAuth Credentials (if using OAuth)
CLAUDE_TASK_SCHEDULER_CLIENT_ID=
CLAUDE_TASK_SCHEDULER_CLIENT_SECRET=

# API Base URL (optional - defaults to production)
CLAUDE_TASK_SCHEDULER_BASE_URL=local://scheduler

# OAuth Tokens (populated automatically after login)
CLAUDE_TASK_SCHEDULER_ACCESS_TOKEN=
CLAUDE_TASK_SCHEDULER_REFRESH_TOKEN=
CLAUDE_TASK_SCHEDULER_TOKEN_EXPIRES_AT=
